# BẮT BUỘC - dùng đúng cùng giá trị với bản Production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FLASK_SECRET_KEY=change-this-to-a-long-random-secret

# TÙY CHỌN - app vẫn chạy nếu không khai báo
APP_ENV=production

# Tên tương thích cũ, không cần tạo nếu đã có các biến chính ở trên:
# SUPABASE_KEY=your-service-role-key
# SECRET_KEY=change-this-to-a-long-random-secret
